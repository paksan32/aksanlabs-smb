# ============================================================
# Aksan Labs SMB Site — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# Shared secret with admin.aksanlabs.com's /api/public/leads ingest endpoint.
# Must match the LEADS_INGEST_SECRET value set in the aksanlabs-platform project.
LEADS_INGEST_SECRET=your-shared-secret

# admin.aksanlabs.com's public leads ingest endpoint — where contact-form leads are sent.
ADMIN_LEADS_URL=https://admin.aksanlabs.com/api/public/leads
